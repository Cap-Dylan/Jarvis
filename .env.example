# Jarvis Environment Configuration
# Copy to .env and fill in real values:  cp .env.example .env
# .env is in .gitignore — never commit real tokens.


# ── Home Assistant ────────────────────────────────────────────────
# HA_URL: where Home Assistant is reachable from this machine.
#   - Same machine:        http://localhost:8123
#   - Other LAN host:      http://<HA_LAN_IP>:8123
#   - Tailscale mesh:      http://<HA_TAILSCALE_NAME>.<tailnet>.ts.net:8123
# HA_TOKEN: HA → Profile → Security → Long-Lived Access Tokens → Create
HA_URL=http://localhost:8123
HA_TOKEN=your_long_lived_access_token_here


# ── Ollama ────────────────────────────────────────────────────────
# Where the LLM lives. Same patterns as HA_URL above.
OLLAMA_URL=http://localhost:11434

# OLLAMA_MODEL — main brain (chat, tool decisions). Needs solid JSON-mode support.
#   Recommended: qwen3:14b, llama3.1:8b-instruct-q5_K_M
OLLAMA_MODEL=qwen3:14b

# OLLAMA_COLOR_MODEL — small fast model for color-temperature reasoning.
# Picked for low latency on a tight, repetitive task. See eval_*.py for why.
OLLAMA_COLOR_MODEL=llama3.2:3b


# ── Matrix (chat interface) ───────────────────────────────────────
# Self-hosted Matrix homeserver (Continuwuity / Conduit / Synapse).
# The bot logs in with username + password to obtain a session, then
# uses MATRIX_ACCESS_TOKEN for the alerting webhook (separate code path).
MATRIX_HOMESERVER=http://localhost:6167
MATRIX_USER=@jarvis:your-homeserver
MATRIX_PASSWORD=your_matrix_password_here
MATRIX_ROOM_ID=!your_room_id_here:your-homeserver
MATRIX_ACCESS_TOKEN=your_matrix_access_token_here
