# ── Secrets ───────────────────────────────────────────────────────
# Never commit. Real tokens belong in .env which lives only on
# deployed machines. Copy .env.example → .env to set up locally.
.env
.env.local
.env.backup
*.env
!.env.example


# ── Runtime data ──────────────────────────────────────────────────
# decisions.jsonl is generated by the running agent — every motion
# event and chat command goes here. It contains timestamps that
# reveal home occupancy patterns, so it stays out of git.
decisions.jsonl
*.log
*.save


# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual envs
venv/
.venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg


# ── Tooling ───────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/


# ── IDE / editor ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~


# ── OS junk ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
